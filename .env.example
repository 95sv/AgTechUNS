# PostgreSQL
POSTGRES_USER=agtech
POSTGRES_PASSWORD=agtech_pass
POSTGRES_DB=agtech_db

# InfluxDB
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=agtech-super-secret-token
INFLUXDB_ORG=agtech_org
INFLUXDB_BUCKET=agtech_data
INFLUXDB_USER=agtech
INFLUXDB_PASSWORD=agtech_pass

# MQTT Broker
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883

# JWT Auth
SECRET_KEY=cambia-esta-clave-secreta-en-produccion
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Open-Meteo (no requiere API key, es gratuito)
WEATHER_API_URL=https://api.open-meteo.com/v1/forecast

# SendGrid (notificaciones por email)
SENDGRID_API_KEY=SG.tu-api-key-aqui
SENDGRID_FROM_EMAIL=agtech@tudominio.com

# Google Earth Engine (imágenes satelitales)
GEE_SERVICE_ACCOUNT=tu-service-account@tu-proyecto.iam.gserviceaccount.com
GEE_KEY_FILE=gee_key.json

# Analytics Engine (batch)
ANALYTICS_BATCH_HOUR=2
ANALYTICS_BATCH_MINUTE=0
